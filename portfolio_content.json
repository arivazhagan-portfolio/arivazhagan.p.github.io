  "code": 200,
  "data": {
    "description": "",
    "external": {},
    "html": "<html lang=\"en\"><head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Arivazhagan P | Pharmacist &amp; Quality Professional</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&amp;family=DM+Sans:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\">\n<style>\n  :root {\n    --bg: #f0f8ff;\n    --bg2: #e3f2fd;\n    --bg3: #ffffff;\n    --accent: #1565c0;\n    --accent2: #1e88e5;\n    --accent-light: #42a5f5;\n    --sky: #87ceeb;\n    --navy: #0d2147;\n    --text: #1a2e4a;\n    --muted: #546e8a;\n    --card: #ffffff;\n    --border: rgba(21,101,192,0.15);\n    --border-soft: rgba(21,101,192,0.08);\n    --shadow: rgba(21,101,192,0.10);\n  }\n\n  * { margin:0; padding:0; box-sizing:border-box; }\n  html { scroll-behavior: smooth; }\n\n  body {\n    background: var(--bg);\n    color: var(--text);\n    font-family: 'DM Sans', sans-serif;\n    overflow-x: hidden;\n  }\n\n  /* ── NAV ── */\n  nav {\n    position: fixed; top:0; left:0; right:0; z-index:100;\n    display:flex; align-items:center; justify-content:space-between;\n    padding: 16px 6vw;\n    background: rgba(255,255,255,0.92);\n    backdrop-filter: blur(16px);\n    border-bottom: 1px solid var(--border);\n    box-shadow: 0 2px 20px var(--shadow);\n  }\n  .nav-logo {\n    font-family: 'Playfair Display', serif;\n    font-size: 1.3rem;\n    color: var(--accent);\n    letter-spacing: 1px;\n  }\n  .nav-links { display:flex; gap:2.2rem; list-style:none; }\n  .nav-links a {\n    text-decoration:none; color: var(--muted);\n    font-size: 0.88rem; font-weight:600; letter-spacing:0.5px;\n    transition: color 0.3s;\n    text-transform: uppercase;\n  }\n  .nav-links a:hover { color: var(--accent); }\n\n  /* ── HERO ── */\n  #hero {\n    min-height: 100vh;\n    display: flex; align-items:center; justify-content:center;\n    position: relative;\n    overflow: hidden;\n    padding: 110px 6vw 70px;\n    background: linear-gradient(145deg, #e3f2fd 0%, #f0f8ff 50%, #e8f4fd 100%);\n  }\n\n  /* Molecule background */\n  .molecule-bg {\n    position: absolute; inset:0; pointer-events:none;\n    opacity: 0.08;\n  }\n  .molecule-bg svg { width:100%; height:100%; }\n\n  /* Sky blue glow blobs */\n  .blob {\n    position:absolute; border-radius:50%;\n    filter: blur(80px); pointer-events:none; z-index:0;\n  }\n  .blob1 { width:500px; height:500px; background:rgba(33,150,243,0.12); top:-100px; right:-80px; }\n  .blob2 { width:400px; height:400px; background:rgba(135,206,235,0.18); bottom:-80px; left:-80px; }\n\n  .hero-inner {\n    position:relative; z-index:1;\n    display:flex; align-items:center; gap:6vw;\n    max-width: 1100px; width:100%;\n  }\n\n  .hero-photo {\n    flex-shrink:0;\n    width: 240px; height:240px;\n    border-radius:50%;\n    border: 4px solid var(--accent);\n    box-shadow: 0 0 0 8px rgba(21,101,192,0.08), 0 16px 48px rgba(21,101,192,0.18);\n    overflow:hidden;\n    background: var(--bg2);\n    display:flex; align-items:center; justify-content:center;\n    font-size:5rem;\n    animation: floatY 4s ease-in-out infinite;\n  }\n  @keyframes floatY {\n    0%,100% { transform: translateY(0); }\n    50% { transform: translateY(-12px); }\n  }\n\n  .hero-text { flex:1; }\n  .hero-tag {\n    display:inline-block;\n    background: rgba(21,101,192,0.08);\n    border: 1px solid rgba(21,101,192,0.25);\n    color: var(--accent);\n    font-size:0.78rem; letter-spacing:2px; text-transform:uppercase;\n    padding:5px 14px; border-radius:20px; margin-bottom:1.2rem;\n    animation: fadeUp 0.6s ease both;\n    font-weight:600;\n  }\n  .hero-name {\n    font-family: 'Playfair Display', serif;\n    font-size: clamp(2.2rem, 5vw, 3.8rem);\n    font-weight:900; line-height:1.1;\n    color: var(--navy);\n    animation: fadeUp 0.7s 0.1s ease both;\n  }\n  .hero-name span { color: var(--accent); }\n  .hero-title {\n    font-size: 1.05rem; color: var(--accent2);\n    margin: 0.8rem 0 1.4rem;\n    font-weight:500;\n    animation: fadeUp 0.7s 0.2s ease both;\n  }\n  .hero-desc {\n    color: var(--muted); font-size: 0.97rem; line-height:1.85;\n    max-width:520px;\n    animation: fadeUp 0.7s 0.3s ease both;\n  }\n  .hero-btns {\n    display:flex; gap:1rem; margin-top:2rem; flex-wrap:wrap;\n    animation: fadeUp 0.7s 0.4s ease both;\n  }\n  .btn-primary {\n    background: var(--accent); color: #fff;\n    padding:12px 30px; border-radius:8px;\n    font-weight:600; font-size:0.9rem; text-decoration:none;\n    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;\n    letter-spacing:0.5px;\n    box-shadow: 0 4px 16px rgba(21,101,192,0.28);\n  }\n  .btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(21,101,192,0.38); background:#1976d2; }\n  .btn-outline {\n    border:2px solid var(--accent); color:var(--accent);\n    padding:12px 30px; border-radius:8px;\n    font-weight:600; font-size:0.9rem; text-decoration:none;\n    transition: background 0.2s, color 0.2s;\n    background: transparent;\n  }\n  .btn-outline:hover { background:var(--accent); color:#fff; }\n\n  @keyframes fadeUp {\n    from { opacity:0; transform:translateY(24px); }\n    to   { opacity:1; transform:translateY(0); }\n  }\n\n  /* Rx pill ribbon */\n  .rx-ribbon {\n    position:absolute; bottom:30px; right:6vw;\n    display:flex; gap:1rem; align-items:center;\n    animation: fadeUp 1s 0.6s ease both;\n  }\n  .rx-pill {\n    background: #fff; border:1px solid var(--border);\n    padding:8px 18px; border-radius:30px;\n    font-size:0.78rem; color:var(--muted);\n    display:flex; align-items:center; gap:6px;\n    box-shadow: 0 2px 10px var(--shadow);\n  }\n  .rx-pill span { color:var(--accent); font-weight:700; }\n\n  /* ── SECTIONS SHARED ── */\n  section { padding: 90px 6vw; }\n  .section-label {\n    font-size:0.75rem; letter-spacing:3px; text-transform:uppercase;\n    color:var(--accent-light); margin-bottom:0.5rem; font-weight:600;\n  }\n  .section-title {\n    font-family:'Playfair Display', serif;\n    font-size: clamp(1.8rem, 3.5vw, 2.8rem);\n    font-weight:700; margin-bottom:2.5rem;\n    color: var(--navy);\n  }\n  .divider {\n    width:60px; height:3px;\n    background: linear-gradient(90deg, var(--accent), var(--accent-light), transparent);\n    margin-bottom:2.5rem;\n    border-radius:2px;\n  }\n\n  /* ── ABOUT ── */\n  #about {\n    background: #ffffff;\n    border-top: 1px solid var(--border-soft);\n    box-shadow: inset 0 1px 0 var(--border-soft);\n  }\n  .about-grid {\n    display:grid; grid-template-columns:1fr 1fr; gap:4vw;\n    align-items:start; max-width:1100px; margin:0 auto;\n  }\n  .about-info p {\n    color:var(--muted); line-height:1.9; margin-bottom:1.2rem; font-size:0.97rem;\n  }\n  .about-stats {\n    display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; margin-top:2rem;\n  }\n  .stat-box {\n    background: var(--bg); border:1px solid var(--border);\n    border-radius:14px; padding:20px;\n    text-align:center;\n    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;\n  }\n  .stat-box:hover { border-color:var(--accent); transform:translateY(-4px); box-shadow:0 8px 24px var(--shadow); }\n  .stat-box .num {\n    font-family:'Playfair Display',serif;\n    font-size:2rem; font-weight:700; color:var(--accent);\n  }\n  .stat-box .lbl { font-size:0.78rem; color:var(--muted); margin-top:4px; }\n\n  .about-skills h3 {\n    font-family:'Playfair Display',serif; font-size:1.3rem; margin-bottom:1.5rem;\n    color:var(--navy);\n  }\n  .skill-tags { display:flex; flex-wrap:wrap; gap:0.7rem; }\n  .skill-tag {\n    background:rgba(21,101,192,0.06); border:1px solid rgba(21,101,192,0.2);\n    color:var(--accent); font-size:0.82rem; padding:7px 16px;\n    border-radius:20px; transition:background 0.2s, border-color 0.2s, color 0.2s;\n    font-weight:500;\n  }\n  .skill-tag:hover { background:var(--accent); color:#fff; border-color:var(--accent); }\n\n  /* ── EDUCATION ── */\n  #education {\n    background: var(--bg);\n    border-top:1px solid var(--border-soft);\n  }\n  .edu-timeline { max-width:800px; }\n  .edu-item {\n    display:flex; gap:2rem; margin-bottom:2.5rem;\n    position:relative;\n  }\n  .edu-item::before {\n    content:''; position:absolute; left:19px; top:40px; bottom:-20px;\n    width:2px; background: linear-gradient(to bottom, var(--accent-light), transparent);\n  }\n  .edu-item:last-child::before { display:none; }\n  .edu-dot {\n    flex-shrink:0; width:40px; height:40px; border-radius:50%;\n    background: var(--accent); border:3px solid #fff;\n    display:flex; align-items:center; justify-content:center;\n    font-size:1rem; margin-top:4px;\n    box-shadow:0 4px 14px rgba(21,101,192,0.28);\n    transition: transform 0.35s cubic-bezier(.34,1.56,.64,1), box-shadow 0.35s;\n    z-index:1;\n  }\n  .edu-item:hover .edu-dot {\n    transform: scale(1.18);\n    box-shadow: 0 0 0 6px rgba(21,101,192,0.12), 0 6px 20px rgba(21,101,192,0.35);\n  }\n\n  /* perspective wrapper on the timeline for 3D pop */\n  .edu-timeline { perspective: 1000px; }\n\n  .edu-body {\n    background: #fff;\n    border: 1.5px solid var(--border);\n    border-radius: 16px;\n    padding: 22px 26px;\n    flex: 1;\n    box-shadow: 0 4px 18px rgba(21,101,192,0.09);\n    transition:\n      transform 0.38s cubic-bezier(.34,1.56,.64,1),\n      box-shadow 0.38s ease,\n      border-color 0.28s ease,\n      background 0.28s ease;\n    transform-style: preserve-3d;\n    will-change: transform;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* Shimmer stripe on hover */\n  .edu-body::after {\n    content:'';\n    position:absolute; inset:0;\n    background: linear-gradient(135deg,\n      rgba(255,255,255,0) 40%,\n      rgba(21,101,192,0.07) 60%,\n      rgba(255,255,255,0) 80%);\n    opacity:0;\n    transition: opacity 0.4s ease;\n    pointer-events:none;\n    border-radius:16px;\n  }\n\n  /* Top accent bar that slides in on hover */\n  .edu-body::before {\n    content:'';\n    position:absolute; top:0; left:0; right:0;\n    height:4px;\n    background: linear-gradient(90deg, var(--accent), var(--accent-light));\n    border-radius:16px 16px 0 0;\n    transform: scaleX(0);\n    transform-origin: left;\n    transition: transform 0.35s cubic-bezier(.34,1.56,.64,1);\n  }\n\n  .edu-body:hover {\n    transform: translateY(-10px) scale(1.025) rotateX(2deg);\n    box-shadow:\n      0 20px 48px rgba(21,101,192,0.22),\n      0 6px 16px rgba(21,101,192,0.14),\n      0 0 0 1.5px rgba(21,101,192,0.25);\n    border-color: var(--accent);\n    background: linear-gradient(160deg, #fff 70%, #e8f4fd 100%);\n  }\n  .edu-body:hover::after { opacity: 1; }\n  .edu-body:hover::before { transform: scaleX(1); }\n\n  .edu-degree { font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--navy); }\n  .edu-inst { color:var(--accent2); font-size:0.88rem; margin:4px 0; font-weight:500; }\n  .edu-meta { display:flex; gap:1.5rem; margin-top:8px; flex-wrap:wrap; }\n  .edu-yr { font-size:0.8rem; color:var(--muted); }\n  .edu-gpa {\n    font-size:0.8rem; color:#0d7a3e; font-weight:600;\n    background:rgba(13,122,62,0.08); padding:2px 10px; border-radius:10px;\n  }\n\n  /* ── EXPERIENCE ── */\n  #experience {\n    background: #ffffff;\n    border-top:1px solid var(--border-soft);\n  }\n  .exp-cards { max-width:900px; display:flex; flex-direction:column; gap:2rem; }\n  .exp-card {\n    background:#fff; border:1px solid var(--border);\n    border-radius:16px; padding:28px 30px;\n    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;\n    position:relative; overflow:hidden;\n    box-shadow: 0 2px 16px var(--shadow);\n  }\n  .exp-card::before {\n    content:''; position:absolute; left:0; top:0; bottom:0;\n    width:5px; background: linear-gradient(to bottom, var(--accent), var(--accent-light));\n    border-radius:4px 0 0 4px;\n  }\n  .exp-card:nth-child(2)::before { background: linear-gradient(to bottom, #1e88e5, #64b5f6); }\n  .exp-card:nth-child(3)::before { background: linear-gradient(to bottom, #0288d1, #4fc3f7); }\n  .exp-card:nth-child(4)::before { background: linear-gradient(to bottom, #0097a7, #4dd0e1); }\n  .exp-card:hover { border-color:var(--accent); transform:translateX(6px); box-shadow:0 8px 32px rgba(21,101,192,0.16); }\n  .exp-header { display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:1rem; }\n  .exp-role { font-family:'Playfair Display',serif; font-size:1.15rem; color:var(--navy); }\n  .exp-company { color:var(--accent2); font-size:0.9rem; margin-top:3px; font-weight:500; }\n  .exp-period {\n    background:rgba(21,101,192,0.06); border:1px solid rgba(21,101,192,0.2);\n    padding:5px 14px; border-radius:20px;\n    font-size:0.78rem; color:var(--accent); white-space:nowrap; font-weight:600;\n  }\n  .exp-list { margin-top:1rem; list-style:none; display:flex; flex-direction:column; gap:0.6rem; }\n  .exp-list li {\n    color:var(--muted); font-size:0.9rem; line-height:1.7;\n    padding-left:1.2rem; position:relative;\n  }\n  .exp-list li::before {\n    content:'▹'; position:absolute; left:0; color:var(--accent); font-size:0.8rem; top:2px;\n  }\n\n  /* ── CONTACT ── */\n  #contact {\n    border-top:1px solid var(--border-soft);\n    text-align:center;\n    background: var(--bg);\n  }\n  .contact-inner { max-width:700px; margin:0 auto; }\n  .contact-desc { color:var(--muted); line-height:1.8; margin-bottom:3rem; font-size:0.97rem; }\n  .contact-cards {\n    display:flex; justify-content:center; gap:1.5rem; flex-wrap:wrap;\n    margin-bottom:3rem;\n  }\n  .contact-card {\n    background:#fff; border:1px solid var(--border);\n    border-radius:16px; padding:24px 28px;\n    display:flex; flex-direction:column; align-items:center; gap:10px;\n    text-decoration:none; min-width:150px;\n    transition:border-color 0.3s, transform 0.3s, box-shadow 0.3s;\n    box-shadow: 0 2px 12px var(--shadow);\n  }\n  .contact-card:hover {\n    border-color:var(--accent); transform:translateY(-6px);\n    box-shadow:0 12px 32px rgba(21,101,192,0.18);\n  }\n  .contact-card .icon { font-size:2rem; }\n  .contact-card .c-label { font-size:0.78rem; text-transform:uppercase; letter-spacing:1px; color:var(--muted); font-weight:600; }\n  .contact-card .c-val { font-size:0.88rem; color:var(--text); word-break:break-all; text-align:center; font-weight:500; }\n\n  .cc-insta:hover { border-color:#e1306c; box-shadow:0 12px 32px rgba(225,48,108,0.18); }\n  .cc-wa:hover { border-color:#25d366; box-shadow:0 12px 32px rgba(37,211,102,0.18); }\n  .cc-mail:hover { border-color:var(--accent2); box-shadow:0 12px 32px rgba(30,136,229,0.18); }\n\n  /* ── FOOTER ── */\n  footer {\n    text-align:center; padding:24px 6vw;\n    border-top:1px solid var(--border);\n    color:var(--muted); font-size:0.82rem;\n    background:#fff;\n  }\n  footer span { color:var(--accent); font-weight:600; }\n\n  /* ── Molecule SVG pattern ── */\n  .rx-mark {\n    font-family:'Playfair Display',serif;\n    font-size:3rem; color:var(--accent); opacity:0.05;\n    position:absolute; user-select:none; pointer-events:none;\n    font-weight:900;\n  }\n\n  /* Responsive */\n  @media(max-width:768px){\n    .hero-inner { flex-direction:column; text-align:center; }\n    .hero-photo { width:180px; height:180px; }\n    .hero-desc { margin:0 auto; }\n    .hero-btns { justify-content:center; }\n    .rx-ribbon { display:none; }\n    .about-grid { grid-template-columns:1fr; }\n    nav { padding:14px 4vw; }\n    .nav-links { gap:1.2rem; }\n    .nav-links a { font-size:0.78rem; }\n    section { padding:70px 5vw; }\n  }\n  @media(max-width:480px){\n    .nav-links { gap:0.8rem; }\n    .contact-cards { flex-direction:column; align-items:center; }\n    .contact-card { width:100%; max-width:280px; }\n  }\n</style>\n</head>\n<body>\n\n<!-- NAV -->\n<nav>\n  <div class=\"nav-logo\">Arivazhagan P</div>\n  <ul class=\"nav-links\">\n    <li><a href=\"#about\">About</a></li>\n    <li><a href=\"#education\">Education</a></li>\n    <li><a href=\"#experience\">Experience</a></li>\n    <li><a href=\"#contact\">Contact</a></li>\n  </ul>\n</nav>\n\n<!-- HERO -->\n<section id=\"hero\">\n  <div class=\"blob blob1\"></div>\n  <div class=\"blob blob2\"></div>\n\n  <!-- Floating Rx watermarks -->\n  <span class=\"rx-mark\" style=\"top:12%;left:4%;\">℞</span>\n  <span class=\"rx-mark\" style=\"top:60%;right:5%;font-size:5rem;\">⚕</span>\n  <span class=\"rx-mark\" style=\"bottom:10%;left:30%;font-size:2rem;\">⚗</span>\n\n  <!-- Molecule pattern SVG -->\n  <div class=\"molecule-bg\">\n    <svg viewBox=\"0 0 1200 700\" preserveAspectRatio=\"xMidYMid slice\" xmlns=\"http://www.w3.org/2000/svg\">\n      <defs>\n        <style>.mc{fill:none;stroke:#1565c0;stroke-width:1.5}.md{fill:#1565c0}</style>\n      </defs>\n      <!-- Hexagon molecular structure -->\n      <g opacity=\"0.8\">\n        <polygon class=\"mc\" points=\"200,120 240,100 280,120 280,160 240,180 200,160\"></polygon>\n        <polygon class=\"mc\" points=\"280,120 320,100 360,120 360,160 320,180 280,160\"></polygon>\n        <polygon class=\"mc\" points=\"360,120 400,100 440,120 440,160 400,180 360,160\"></polygon>\n        <line class=\"mc\" x1=\"240\" y1=\"180\" x2=\"240\" y2=\"230\"></line>\n        <circle class=\"md\" cx=\"240\" cy=\"240\" r=\"6\"></circle>\n        <line class=\"mc\" x1=\"320\" y1=\"100\" x2=\"320\" y2=\"50\"></line>\n        <circle class=\"md\" cx=\"320\" cy=\"42\" r=\"6\"></circle>\n        <line class=\"mc\" x1=\"400\" y1=\"180\" x2=\"400\" y2=\"230\"></line>\n        <circle class=\"md\" cx=\"400\" cy=\"240\" r=\"6\"></circle>\n\n        <polygon class=\"mc\" points=\"700,300 740,280 780,300 780,340 740,360 700,340\"></polygon>\n        <polygon class=\"mc\" points=\"780,300 820,280 860,300 860,340 820,360 780,340\"></polygon>\n        <line class=\"mc\" x1=\"740\" y1=\"280\" x2=\"740\" y2=\"230\"></line>\n        <circle class=\"md\" cx=\"740\" cy=\"222\" r=\"6\"></circle>\n        <line class=\"mc\" x1=\"820\" y1=\"360\" x2=\"820\" y2=\"410\"></line>\n        <circle class=\"md\" cx=\"820\" cy=\"418\" r=\"6\"></circle>\n        <line class=\"mc\" x1=\"860\" y1=\"310\" x2=\"920\" y2=\"310\"></line>\n        <circle class=\"md\" cx=\"928\" cy=\"310\" r=\"6\"></circle>\n\n        <polygon class=\"mc\" points=\"900,500 940,480 980,500 980,540 940,560 900,540\"></polygon>\n        <line class=\"mc\" x1=\"940\" y1=\"560\" x2=\"940\" y2=\"610\"></line>\n        <circle class=\"md\" cx=\"940\" cy=\"618\" r=\"6\"></circle>\n        <line class=\"mc\" x1=\"980\" y1=\"510\" x2=\"1030\" y2=\"510\"></line>\n        <circle class=\"md\" cx=\"1038\" cy=\"510\" r=\"8\"></circle>\n\n        <line class=\"mc\" x1=\"150\" y1=\"400\" x2=\"200\" y2=\"350\"></line>\n        <circle class=\"md\" cx=\"145\" cy=\"405\" r=\"6\"></circle>\n        <polygon class=\"mc\" points=\"200,320 240,300 280,320 280,360 240,380 200,360\"></polygon>\n        <line class=\"mc\" x1=\"280\" y1=\"340\" x2=\"330\" y2=\"340\"></line>\n        <circle class=\"md\" cx=\"338\" cy=\"340\" r=\"6\"></circle>\n        <line class=\"mc\" x1=\"240\" y1=\"380\" x2=\"240\" y2=\"430\"></line>\n        <circle class=\"md\" cx=\"240\" cy=\"438\" r=\"6\"></circle>\n      </g>\n    </svg>\n  </div>\n\n  <div class=\"hero-inner\">\n    <div class=\"hero-photo\">🧪</div>\n    <div class=\"hero-text\">\n      <div class=\"hero-tag\">📋 B.Pharm · Quality &amp; Product Support</div>\n      <h1 class=\"hero-name\">Arivazhagan <span>P</span></h1>\n      <p class=\"hero-title\">Manager, Quality &amp; Product Support · Pharmaceutical Professional</p>\n      <p class=\"hero-desc\">\n        A seasoned pharmacist and quality professional with 8+ years of experience spanning hospital pharmacy, pharmaceutical manufacturing, and quality management. Dedicated to patient safety, regulatory compliance, and product excellence.\n      </p>\n      <div class=\"hero-btns\">\n        <a href=\"#experience\" class=\"btn-primary\">View Experi